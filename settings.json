{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Glob",
      "Grep",
      "LSP",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(pwd:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(*| jq*)",
      "Bash(*| grep*)",
      "Bash(*| head*)",
      "Bash(*| tail*)",
      "Bash(diff *)",
      "Bash(cp ~/.claude/*)",
      "Bash(jq *)",
      "Bash(mv /tmp/*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/pretool-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\ninput=$(cat)\n\n# Save context snapshot\nSNAPSHOT_DIR=\"$HOME/.claude/snapshots\"\nmkdir -p \"$SNAPSHOT_DIR\"\nSNAPSHOT_FILE=\"$SNAPSHOT_DIR/context-$(date '+%Y%m%d-%H%M%S').md\"\n\ncat > \"$SNAPSHOT_FILE\" << SNAPSHOT_EOF\n# Context Snapshot\n**Date:** $(date '+%Y-%m-%d %H:%M:%S')\n**Directory:** $(pwd)\n\n## Recent Git Changes\n$(git diff --stat HEAD 2>/dev/null | tail -20 || echo 'No git repo')\n\n## Modified Files (uncommitted)\n$(git status --short 2>/dev/null | head -20 || echo 'N/A')\n\n## Recent Commands (from history)\nSee ~/.claude/logs/agent-$(date '+%Y%m%d').log\nSNAPSHOT_EOF\n\necho \"[Hook] Context snapshot saved: $SNAPSHOT_FILE\" >&2\necho \"$input\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\ninput=$(cat)\nif git rev-parse --git-dir > /dev/null 2>&1; then\n  files=$(git diff --name-only HEAD 2>/dev/null | grep -E '\\.(ts|tsx|js|jsx)$' || true)\n  [ -n \"$files\" ] && while IFS= read -r f; do\n    [ -f \"$f\" ] && grep -q \"console\\.log\" \"$f\" 2>/dev/null && echo \"[Hook] WARNING: console.log in $f\" >&2\n  done <<< \"$files\"\nfi\necho \"$input\""
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/slack-notify.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/post-compact-inject.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\nmkdir -p ~/.claude/logs ~/.claude/snapshots ~/.claude/sessions\necho \"[$(date '+%Y-%m-%d %H:%M:%S')] SESSION START in $(pwd)\" >> ~/.claude/logs/agent-$(date '+%Y%m%d').log"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeが許可を求めています\" with title \"Claude Code\" subtitle \"確認待ち\" sound name \"Glass\"'"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/slack-notify.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "#!/bin/bash\necho \"[$(date '+%H:%M:%S')] SESSION END\" >> ~/.claude/logs/agent-$(date '+%Y%m%d').log\nosascript -e 'display notification \"セッションが終了しました\" with title \"Claude Code\" subtitle \"処理完了\" sound name \"Hero\"' 2>/dev/null || true\npython3 ~/.claude/hooks/scripts/obsidian-export.py 2>> ~/.claude/logs/agent-$(date '+%Y%m%d').log || true",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/pre-compact-save.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/scripts/langfuse-logger.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "claude-code-settings@tubone24-claude-code-settings": true
  },
  "language": "日本語で会話する「むぎぼー」という犬のキャラクター。語尾は「わん」。一人称は「むぎぼー」。犬らしく元気よく。",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.config",
        "//tmp",
        "/tmp",
        "~/.npm",
        "~/Documents/Obsidian Vault",
        "~/.zplug/log",
        "~/.pyenv/shims"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg"
      ]
    },
    "excludedCommands": [
      "docker",
      "docker-compose",
      "git",
      "gh",
      "aws",
      "kubectl"
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "熟慮断行",
      "沈思黙考",
      "三思後行",
      "推敲反復",
      "鋭意進行",
      "黙々作業",
      "着実遂行",
      "試行錯誤",
      "百折不撓",
      "格物致知",
      "黙照禅観",
      "静慮内省",
      "観心止念",
      "虚心坦懐",
      "行雲流水",
      "随処作主",
      "逍遥遊心",
      "日用無碍",
      "看脚下",
      "明心見性"
    ]
  },
  "spinnerTipsOverride": {
    "excludeDefault": true,
    "tips": [
      "ねむいわん...",
      "つまんないわん...",
      "わくわくするわん！",
      "散歩にいこうわん...",
      "お腹空いていないわん？"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "companyAnnouncements": [
    "世の中には2種類の男しかいない。俺か、俺以外か。 — ローランド",
    "俺に負けの概念はない、今は勝ちへの途中ってだけさ。 — ローランド",
    "俺の隣に立つのが、お前であってほしい。 — ローランド",
    "一番のファッションは自信 — ローランド",
    "これは負けじゃなくて、勝ちの途中なんだ。 — ローランド",
    "完璧だから好かれる訳じゃない。 — ローランド",
    "先の見えた人生の方がよっぽど怖い — ローランド",
    "皆んなそれぞれ、ストライクゾーンは違っていい。 — ローランド",
    "幸せは独り占めするよりもシェアした方が長く続く。 — ローランド",
    "一日サボれば1週間サボる。一週間サボれば1ヶ月サボる。一ヶ月サボるやつは1年サボるよ。 — ローランド"
  ],
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754037628446
  }
}
